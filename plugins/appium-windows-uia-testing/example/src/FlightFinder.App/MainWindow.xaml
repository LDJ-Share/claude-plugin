<Window
    x:Class="FlightFinder.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Flight Finder Demo"
    Width="760"
    Height="540">

    <!--
        Locator rules this layout demonstrates (see the appium-windows-uia-testing skill):
        * AutomationIds live on PEER-BEARING elements (TextBlock/Control/Button),
        never on a Border/Grid/Panel (those get no UIA peer, so AccessibilityId
        cannot find them).
        * One SHARED id ("ResultCard") per row -> count rows with a native-UIA
        FindAll, no XPath tree-walk.
        * One UNIQUE data-bound id ("OpenResult_{Id}") per row -> target one row.
    -->

    <DockPanel Margin="16">

        <!--
            Top nav. Two real Buttons with AutomationIds; ClickNavAndWait can
            drive either, with a keyboard-Enter fallback.
        -->
        <StackPanel
            Margin="0,0,0,12"
            DockPanel.Dock="Top"
            Orientation="Horizontal">
            <Button
                x:Name="NavSearchButton"
                Padding="14,6"
                AutomationProperties.AutomationId="NavSearch"
                Click="NavSearch_Click"
                Content="Search" />
            <Button
                x:Name="NavAboutButton"
                Margin="8,0,0,0"
                Padding="14,6"
                AutomationProperties.AutomationId="NavAbout"
                Click="NavAbout_Click"
                Content="About" />
        </StackPanel>

        <!--  Content host: both "pages" share the cell; visibility is toggled.  -->
        <Grid>

            <!--  Search page  -->
            <Grid x:Name="SearchPage">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    Orientation="Horizontal">
                    <TextBox
                        Width="180"
                        AutomationProperties.AutomationId="SearchOriginInput"
                        Text="{Binding Origin, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox
                        Width="180"
                        Margin="8,0,0,0"
                        AutomationProperties.AutomationId="SearchDestinationInput"
                        Text="{Binding Destination, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Margin="8,0,0,0"
                        Padding="18,6"
                        AutomationProperties.AutomationId="SearchButton"
                        Click="Search_Click"
                        Content="Search" />
                </StackPanel>

                <TextBlock
                    Grid.Row="1"
                    Margin="2,0,0,8"
                    AutomationProperties.AutomationId="ResultCountText"
                    Text="{Binding StatusText}" />

                <ListView
                    Grid.Row="2"
                    AutomationProperties.AutomationId="ResultsList"
                    ItemsSource="{Binding Results}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <!--
                                Border = visuals only; it gets NO UIA peer, so the
                                counting id sits on the TextBlock inside it.
                            -->
                            <Border
                                Margin="0,0,0,8"
                                Padding="12"
                                BorderBrush="#3D3A39"
                                BorderThickness="1"
                                CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        AutomationProperties.AutomationId="ResultCard"
                                        Text="{Binding CardSummary}" />

                                    <Button
                                        Grid.Column="1"
                                        Padding="14,4"
                                        AutomationProperties.AutomationId="{Binding OpenButtonId}"
                                        Click="OpenResult_Click"
                                        Content="Open" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!--  About page (hidden until the About nav button is clicked)  -->
            <TextBlock
                x:Name="AboutPage"
                AutomationProperties.AutomationId="AboutPageRoot"
                Text="Flight Finder Demo — a generic WPF app for demonstrating Appium NovaWindows UI automation."
                TextWrapping="Wrap"
                Visibility="Collapsed" />
        </Grid>
    </DockPanel>
</Window>
